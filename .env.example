# =================================================================
# ASISTEN-AI-KU - Environment Variables Configuration
# =================================================================
# Salin file ini menjadi .env dan isi nilai yang diperlukan
# Jangan commit file .env yang sudah berisi API Key ke GitHub!
# =================================================================

# --- Google Gemini API Configuration ---
# Dapatkan API Key di: https://aistudio.google.com/
GEMINI_API_KEY=your_api_key_here

# Model yang digunakan (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# --- Optional: Custom System Instructions ---
# Sesuaikan persona asisten AI kamu di sini
# SYSTEM_PROMPT=Anda adalah asisten AI yang membantu pengguna berbahasa Indonesia...

# --- Server Configuration (Opsional) ---
# PORT=3000
# NODE_ENV=development
